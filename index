import { useState, useEffect, useRef } from 'react';
import { Dices, Sparkles, Save, Trash2, Loader2, BookOpen, Calendar, Hash, Image as ImageIcon, Type, X, Upload, Camera } from 'lucide-react';

export default function StudyApp() {
  const [diceValue, setDiceValue] = useState(null);
  const [isRolling, setIsRolling] = useState(false);

  const [inputMode, setInputMode] = useState('text');
  const [explanation, setExplanation] = useState('');
  const [imageData, setImageData] = useState(null);
  const [imagePreview, setImagePreview] = useState(null);
  const [imageMediaType, setImageMediaType] = useState('image/jpeg');

  const [summary, setSummary] = useState('');
  const [memo, setMemo] = useState('');
  const [isSummarizing, setIsSummarizing] = useState(false);
  const [history, setHistory] = useState([]);
  const [error, setError] = useState('');

  const fileInputRef = useRef(null);

  useEffect(() => {
    (async () => {
      try {
        const result = await window.storage.get('study_history');
        if (result?.value) setHistory(JSON.parse(result.value));
      } catch {
        setHistory([]);
      }
    })();
  }, []);

  const rollDice = () => {
    if (isRolling) return;
    setIsRolling(true);
    let count = 0;
    const interval = setInterval(() => {
      setDiceValue(Math.floor(Math.random() * 6) + 1);
      count++;
      if (count > 12) {
        clearInterval(interval);
        setIsRolling(false);
      }
    }, 70);
  };

  const processImage = (file) =>
    new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = (e) => {
        const img = new Image();
        img.onload = () => {
          const MAX = 1500;
          let { width, height } = img;
          if (width > MAX || height > MAX) {
            if (width > height) {
              height = Math.round((height * MAX) / width);
              width = MAX;
            } else {
              width = Math.round((width * MAX) / height);
              height = MAX;
            }
          }
          const canvas = document.createElement('canvas');
          canvas.width = width;
          canvas.height = height;
          const ctx = canvas.getContext('2d');
          ctx.fillStyle = '#fff';
          ctx.fillRect(0, 0, width, height);
          ctx.drawImage(img, 0, 0, width, height);
          const dataUrl = canvas.toDataURL('image/jpeg', 0.85);
          resolve({
            base64: dataUrl.split(',')[1],
            preview: dataUrl,
            mediaType: 'image/jpeg',
          });
        };
        img.onerror = () => reject(new Error('画像を読み込めませんでした'));
        img.src = e.target.result;
      };
      reader.onerror = () => reject(new Error('ファイルを読み込めませんでした'));
      reader.readAsDataURL(file);
    });

  const handleFile = async (file) => {
    if (!file) return;
    if (!file.type.startsWith('image/')) {
      setError('画像ファイルを選択してください');
      return;
    }
    setError('');
    try {
      const { base64, preview, mediaType } = await processImage(file);
      setImageData(base64);
      setImagePreview(preview);
      setImageMediaType(mediaType);
    } catch (e) {
      setError('画像の処理に失敗しました');
    }
  };

  const onFileChange = (e) => handleFile(e.target.files?.[0]);

  const onDrop = (e) => {
    e.preventDefault();
    handleFile(e.dataTransfer.files?.[0]);
  };

  const clearImage = () => {
    setImageData(null);
    setImagePreview(null);
    if (fileInputRef.current) fileInputRef.current.value = '';
  };

  const canSummarize = () => {
    if (isSummarizing) return false;
    if (inputMode === 'text') return explanation.trim().length > 0;
    return imageData !== null;
  };

  const summarize = async () => {
    if (!canSummarize()) return;
    setIsSummarizing(true);
    setError('');
    setSummary('');

    const promptText = `あなたは応用情報技術者試験の家庭教師です。${
      inputMode === 'image' ? '次の画像に写っている解説や問題文を読み取り、' : '以下の解説文を、'
    }後で見返したときに本質がパッと思い出せる「覚えやすい1文（30〜60文字）」に要約してください。要約のみを出力し、前置きや説明は一切不要です。${
      inputMode === 'text' ? `\n\n【解説文】\n${explanation}` : ''
    }`;

    let content;
    if (inputMode === 'image' && imageData) {
      content = [
        {
          type: 'image',
          source: { type: 'base64', media_type: imageMediaType, data: imageData },
        },
        { type: 'text', text: promptText },
      ];
    } else {
      content = promptText;
    }

    try {
      const response = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          model: 'claude-sonnet-4-20250514',
          max_tokens: 400,
          messages: [{ role: 'user', content }],
        }),
      });
      const data = await response.json();
      const text = data.content
        .filter((b) => b.type === 'text')
        .map((b) => b.text)
        .join('')
        .trim();
      if (!text) {
        setError('要約を生成できませんでした。画像が鮮明か確認してください。');
      } else {
        setSummary(text);
      }
    } catch (e) {
      setError('要約に失敗しました。通信状況をご確認ください。');
    }
    setIsSummarizing(false);
  };

  const saveEntry = async () => {
    if (!summary) return;
    const entry = {
      id: Date.now(),
      date: new Date().toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' }),
      source: inputMode,
      explanation: inputMode === 'text' ? explanation : '',
      summary,
      memo,
      problemCount: diceValue,
    };
    const next = [entry, ...history];
    setHistory(next);
    try {
      await window.storage.set('study_history', JSON.stringify(next));
    } catch {}
    setExplanation('');
    setSummary('');
    setMemo('');
    clearImage();
  };

  const deleteEntry = async (id) => {
    const next = history.filter((e) => e.id !== id);
    setHistory(next);
    try {
      await window.storage.set('study_history', JSON.stringify(next));
    } catch {}
  };

  const DiceFace = ({ value }) => {
    const dots = {
      1: [[50, 50]],
      2: [[28, 28], [72, 72]],
      3: [[28, 28], [50, 50], [72, 72]],
      4: [[28, 28], [72, 28], [28, 72], [72, 72]],
      5: [[28, 28], [72, 28], [50, 50], [28, 72], [72, 72]],
      6: [[28, 25], [72, 25], [28, 50], [72, 50], [28, 75], [72, 75]],
    }[value] || [];
    return (
      <svg viewBox="0 0 100 100" className="w-full h-full">
        <rect x="6" y="6" width="88" height="88" rx="14" fill="#fbf7ee" stroke="#1a1a1a" strokeWidth="2.5" />
        {dots.map(([cx, cy], i) => (
          <circle key={i} cx={cx} cy={cy} r="7" fill="#a82828" />
        ))}
      </svg>
    );
  };

  const fontHeading = { fontFamily: '"Shippori Mincho", "Noto Serif JP", "Hiragino Mincho ProN", serif' };
  const fontBody = { fontFamily: '"Noto Sans JP", "Hiragino Kaku Gothic ProN", sans-serif' };

  return (
    <div
      className="min-h-screen w-full p-4 sm:p-8"
      style={{
        ...fontBody,
        background: 'radial-gradient(ellipse at top, #faf6ec 0%, #f0e9d8 100%)',
        backgroundAttachment: 'fixed',
      }}
    >
      <link href="https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@500;700&family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet" />

      <div className="max-w-3xl mx-auto">
        <header className="mb-10 pb-6 border-b-2 border-stone-800 relative">
          <div className="flex items-baseline justify-between flex-wrap gap-2">
            <div>
              <p className="text-xs tracking-[0.4em] text-stone-500 mb-2">DAILY STUDY JOURNAL</p>
              <h1 className="text-3xl sm:text-4xl font-bold text-stone-900 leading-tight" style={fontHeading}>
                応用情報 学習帳
              </h1>
            </div>
            <div className="text-right">
              <p className="text-xs text-stone-500">本日</p>
              <p className="text-sm text-stone-800" style={fontHeading}>
                {new Date().toLocaleDateString('ja-JP', { month: 'long', day: 'numeric', weekday: 'long' })}
              </p>
            </div>
          </div>
          <div
            className="absolute -right-2 top-0 w-12 h-12 rounded border-2 flex items-center justify-center text-white font-bold text-xs"
            style={{ background: '#a82828', borderColor: '#a82828', transform: 'rotate(8deg)', ...fontHeading }}
          >
            学習
          </div>
        </header>

        <section className="mb-10">
          <div className="flex items-center gap-2 mb-4">
            <span className="text-stone-500 text-sm tracking-widest">01</span>
            <Dices className="w-4 h-4 text-stone-700" />
            <h2 className="text-lg font-bold text-stone-800" style={fontHeading}>今日の問題数を決める</h2>
          </div>
          <div className="bg-white/70 backdrop-blur-sm border border-stone-300 rounded-lg p-6 shadow-sm">
            <div className="flex flex-col sm:flex-row items-center gap-6">
              <div
                className="w-32 h-32 flex-shrink-0 transition-transform duration-100"
                style={{ transform: isRolling ? `rotate(${diceValue * 60}deg)` : 'rotate(0deg)' }}
              >
                {diceValue ? (
                  <DiceFace value={diceValue} />
                ) : (
                  <div className="w-full h-full rounded-2xl border-2 border-dashed border-stone-300 flex items-center justify-center text-stone-400 text-xs">
                    ？
                  </div>
                )}
              </div>
              <div className="flex-1 text-center sm:text-left">
                {diceValue && !isRolling ? (
                  <>
                    <p className="text-stone-600 text-sm mb-1">今日の目標</p>
                    <p className="text-3xl font-bold text-stone-900 mb-3" style={fontHeading}>
                      {diceValue} 問 解こう
                    </p>
                  </>
                ) : (
                  <p className="text-stone-500 mb-3">サイコロを振って、今日の問題数を決めましょう</p>
                )}
                <button
                  onClick={rollDice}
                  disabled={isRolling}
                  className="px-6 py-2.5 bg-stone-900 text-white text-sm font-medium hover:bg-stone-700 disabled:opacity-50 transition-colors"
                  style={fontBody}
                >
                  {isRolling ? '振っています…' : diceValue ? 'もう一度振る' : 'サイコロを振る'}
                </button>
              </div>
            </div>
          </div>
        </section>

        <section className="mb-10">
          <div className="flex items-center gap-2 mb-4">
            <span className="text-stone-500 text-sm tracking-widest">02</span>
            <Sparkles className="w-4 h-4 text-stone-700" />
            <h2 className="text-lg font-bold text-stone-800" style={fontHeading}>解説をAIで要約する</h2>
          </div>

          <div className="bg-white/70 backdrop-blur-sm border border-stone-300 rounded-lg p-6 shadow-sm space-y-4">
            <div className="inline-flex bg-stone-100 border border-stone-300 rounded p-1">
              <button
                onClick={() => setInputMode('text')}
                className={`inline-flex items-center gap-1.5 px-3 py-1.5 text-sm rounded transition-colors ${
                  inputMode === 'text' ? 'bg-stone-900 text-white' : 'text-stone-600 hover:text-stone-900'
                }`}
              >
                <Type className="w-3.5 h-3.5" /> テキスト
              </button>
              <button
                onClick={() => setInputMode('image')}
                className={`inline-flex items-center gap-1.5 px-3 py-1.5 text-sm rounded transition-colors ${
                  inputMode === 'image' ? 'bg-stone-900 text-white' : 'text-stone-600 hover:text-stone-900'
                }`}
              >
                <ImageIcon className="w-3.5 h-3.5" /> 写真
              </button>
            </div>

            {inputMode === 'text' && (
              <div>
                <label className="block text-xs text-stone-600 mb-2 tracking-wider">解説文を貼り付け</label>
                <textarea
                  value={explanation}
                  onChange={(e) => setExplanation(e.target.value)}
                  placeholder="例：TCPは信頼性の高い通信を行うため、確認応答や再送制御を行うプロトコルである。"
                  rows={4}
                  className="w-full px-3 py-2 bg-stone-50 border border-stone-300 rounded text-sm text-stone-900 focus:outline-none focus:border-stone-900 resize-none"
                />
              </div>
            )}

            {inputMode === 'image' && (
              <div>
                <label className="block text-xs text-stone-600 mb-2 tracking-wider">解説の写真をアップロード</label>
                <input
                  ref={fileInputRef}
                  type="file"
                  accept="image/*"
                  capture="environment"
                  onChange={onFileChange}
                  className="hidden"
                />

                {!imagePreview ? (
                  <div
                    onDragOver={(e) => e.preventDefault()}
                    onDrop={onDrop}
                    className="border-2 border-dashed border-stone-300 rounded-lg p-8 text-center hover:border-stone-500 transition-colors"
                  >
                    <Upload className="w-8 h-8 text-stone-400 mx-auto mb-2" />
                    <p className="text-sm text-stone-600 mb-3">
                      教科書や問題集のページを撮影/アップロード
                    </p>
                    <div className="flex items-center justify-center gap-2 flex-wrap">
                      <button
                        onClick={() => fileInputRef.current?.click()}
                        className="inline-flex items-center gap-1.5 px-4 py-2 bg-stone-900 text-white text-sm hover:bg-stone-700 transition-colors"
                      >
                        <Camera className="w-4 h-4" /> 写真を選ぶ
                      </button>
                    </div>
                    <p className="text-xs text-stone-400 mt-3">またはここにドラッグ&ドロップ</p>
                  </div>
                ) : (
                  <div className="relative inline-block">
                    <img
                      src={imagePreview}
                      alt="アップロード画像"
                      className="max-h-64 rounded border border-stone-300"
                    />
                    <button
                      onClick={clearImage}
                      className="absolute -top-2 -right-2 w-7 h-7 bg-stone-900 text-white rounded-full flex items-center justify-center hover:bg-red-700 transition-colors shadow-md"
                      aria-label="画像を削除"
                    >
                      <X className="w-4 h-4" />
                    </button>
                  </div>
                )}
              </div>
            )}

            <button
              onClick={summarize}
              disabled={!canSummarize()}
              className="inline-flex items-center gap-2 px-5 py-2 text-sm font-medium text-white disabled:opacity-50 transition-colors"
              style={{ background: '#a82828' }}
            >
              {isSummarizing ? (
                <>
                  <Loader2 className="w-4 h-4 animate-spin" /> {inputMode === 'image' ? '画像を読み取り中…' : '要約中…'}
                </>
              ) : (
                <>
                  <Sparkles className="w-4 h-4" /> AIで1文に要約
                </>
              )}
            </button>

            {error && (
              <p className="text-sm text-red-700 bg-red-50 px-3 py-2 rounded">{error}</p>
            )}

            {summary && (
              <div className="pt-4 border-t border-stone-200 space-y-4">
                <div>
                  <label className="block text-xs text-stone-600 mb-2 tracking-wider">AI要約</label>
                  <div className="px-4 py-3 bg-amber-50/60 border-l-4 border-amber-700 rounded-r">
                    <p className="text-stone-900 leading-relaxed" style={fontHeading}>{summary}</p>
                  </div>
                </div>
                <div>
                  <label className="block text-xs text-stone-600 mb-2 tracking-wider">自分のメモ（任意）</label>
                  <input
                    type="text"
                    value={memo}
                    onChange={(e) => setMemo(e.target.value)}
                    placeholder="例：UDPとの違いを復習する"
                    className="w-full px-3 py-2 bg-stone-50 border border-stone-300 rounded text-sm focus:outline-none focus:border-stone-900"
                  />
                </div>
                <button
                  onClick={saveEntry}
                  className="inline-flex items-center gap-2 px-5 py-2 bg-stone-900 text-white text-sm font-medium hover:bg-stone-700 transition-colors"
                >
                  <Save className="w-4 h-4" /> 学習履歴に保存
                </button>
              </div>
            )}
          </div>
        </section>

        <section className="mb-10">
          <div className="flex items-center gap-2 mb-4">
            <span className="text-stone-500 text-sm tracking-widest">03</span>
            <BookOpen className="w-4 h-4 text-stone-700" />
            <h2 className="text-lg font-bold text-stone-800" style={fontHeading}>
              学習履歴 <span className="text-sm font-normal text-stone-500">（{history.length}件）</span>
            </h2>
          </div>

          {history.length === 0 ? (
            <div className="bg-white/40 border border-dashed border-stone-300 rounded-lg p-8 text-center text-stone-500 text-sm">
              まだ履歴はありません。要約を保存するとここに記録されます。
            </div>
          ) : (
            <div className="space-y-3">
              {history.map((entry) => (
                <article key={entry.id} className="bg-white/70 border border-stone-300 rounded-lg p-5 shadow-sm">
                  <div className="flex items-center justify-between mb-3 text-xs text-stone-500">
                    <div className="flex items-center gap-3 flex-wrap">
                      <span className="inline-flex items-center gap-1"><Calendar className="w-3 h-3" />{entry.date}</span>
                      {entry.problemCount && (
                        <span className="inline-flex items-center gap-1"><Hash className="w-3 h-3" />{entry.problemCount}問</span>
                      )}
                      <span className="inline-flex items-center gap-1">
                        {entry.source === 'image' ? <ImageIcon className="w-3 h-3" /> : <Type className="w-3 h-3" />}
                        {entry.source === 'image' ? '写真から' : 'テキストから'}
                      </span>
                    </div>
                    <button
                      onClick={() => deleteEntry(entry.id)}
                      className="text-stone-400 hover:text-red-700 transition-colors"
                      aria-label="削除"
                    >
                      <Trash2 className="w-4 h-4" />
                    </button>
                  </div>
                  <p className="text-stone-900 mb-2 leading-relaxed" style={fontHeading}>{entry.summary}</p>
                  {entry.memo && (
                    <p className="text-sm text-stone-600 pl-3 border-l-2 border-stone-300">
                      <span className="text-xs text-stone-400 mr-2">メモ</span>{entry.memo}
                    </p>
                  )}
                </article>
              ))}
            </div>
          )}
        </section>

        <footer className="mt-12 pt-6 border-t border-stone-300 text-center text-xs text-stone-500">
          応用情報技術者試験 学習帳 — Built for daily practice
        </footer>
      </div>
    </div>
  );
}
